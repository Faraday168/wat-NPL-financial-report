rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stats/site {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['views','updatedAt']);
    }
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
